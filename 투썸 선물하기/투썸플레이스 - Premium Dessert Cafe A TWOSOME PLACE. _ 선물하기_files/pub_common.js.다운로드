// 아이폰 이벤트 제어
// Pinch Zoom 끄기
document.documentElement.addEventListener('touchstart', function (event) {
	if (event.touches.length > 1) {
		event.preventDefault();
	}
}, false);
// Double tab Zoom 끄기
var lastTouchEnd = 0;
document.documentElement.addEventListener('touchend', function (event) {
	var now = (new Date()).getTime();
	if (now - lastTouchEnd <= 300) {
		event.preventDefault();
	}
	lastTouchEnd = now;
}, false);

// swiper 로딩
function loadSwiperProgress(el) {
	var swiperList = $(el + ' .swiper-slide');
	if (swiperList.length > 1) {
		var swiperObj = new Swiper(el + ' .swiper-container', {
			loop: true,
			// simulateTouch: false,
			pagination: {
				el: el + ' .swiper-pagination',
				type: 'progressbar',
			},
			navigation: {
				nextEl: el + ' .swiper-button-next',
				prevEl: el + ' .swiper-button-prev',
			},
			paginationClickable: true,
			centeredSlides: true,
			slidesPerView: 1.3,
			spaceBetween: 16,
			observer: true,
			observeParents: true,
			on: {
				slideChangeTransitionStart: function () {
					var swiper = this;
					var $this = $(el + ' .swiper-container');
					var duplicateNum = $this.find('.swiper-slide-duplicate').length;
					var totalNum = swiper.slides.length - duplicateNum;
					if (swiper.params.loop) {
						currentNum = $this.find('.swiper-slide-active').data('swiper-slide-index') + 1; // loop : true 일 경우
					} else {
						currentNum = this.activeIndex + 1; // loop : false 일 경우
					}
					totalNum = '0' + totalNum;
					currentNum = '0' + currentNum;
					$this.find('.swiper-pagination-total').text(totalNum.slice(-2));
					$this.find('.swiper-pagination-current').text(currentNum.slice(-2));
				},
			},
		});
	} else {
		swiperList.show();
	}
}

// layer 팝업 로딩
function openPopLayer(elId) {
	$('html, body').css({'overflow':'hidden', 'position':'relative'});
	$('a, button').siblings().removeClass('layer_focus');
	$('.layer_content').attr('tabindex','0');
	$('.layer_content').focus();

	// 레이어 팝업에 full 전체 팝업이면 dim append 하지 않음.
	if(!$(elId).hasClass('full')) {
		$('html body').append('<div class="dim"></div>');
	}
	
	$(elId).find('.btn_layer_close, .under_close').blur();
	if ($(elId).height() >= $(window).height()){
		$(elId).find('.layer_con').css({
			'height': $(window).height() - 160,
			'overflow-y': 'auto'
		});
	} else {
		$(elId).find('.layer_con').css('height', 'inherit');
	}

	layer = function() {
		$(elId).css({
			'top': ($(window).height() / 2) - ($(elId).height() / 2),
			// 'left': ($(window).width() - ($(elId).width() + 32)) / 2,
			'left': '24px',
			'visibility':'visible'
		});
	}

	$('.dim').css({
		'width': $('html, body').width(),
		'height': $(document).height()
	}).show();

	layer();

	$(elId).show().attr('tabindex', 0).focus();

	$(elId).find('iframe').css({
		'width': '100%',
		'height': $(elId).find('.layer_con').height() - 7
	});

	$(window).on('resize', function(){
		$(elId).find('.layer_con').css({
			'height': $(window).height() - 160,
			'overflow-y': 'auto'
		});
		layer();
		$('.dim').css({
			'width': $('html, body').width(),
			'height': $(document).height()
		});
	});
}

// layer 팝업 닫기
function closePopLayer(elId) {
	var ifrmae_num = $(this).parents('.layer').find('iframe').length;
	$(elId).removeAttr('style');
	$(elId).find('.layer_con').removeAttr('style');
	$(elId).removeAttr('tabindex').hide();
	var dimm = 0;
	$('.layer').each(function(){
		if ($(this).attr('tabindex') == 0) {
			dimm += 1;
		}
	});
	if(dimm == 0){
		//$('.dim').hide();
		$('.dim:not(.not)').remove();
		$('.dim.not').hide();
		$('html, body').css({'overflow':'', 'position':''});
	} else {
		$('.dim:not(.not)').remove();
		$('.dim.not').hide();
	}

	// if (ifrmae_num) {
	//     $('.layer_content.video iframe')[0].contentWindow.postMessage('{"event":"command","func":"' + 'stopVideo' + '","args":""}', '*');
	// }

	$(elId).hide();
	var $layerBtn = $('.' + $(elId).attr('id'));
	$layerBtn.focus();
}

