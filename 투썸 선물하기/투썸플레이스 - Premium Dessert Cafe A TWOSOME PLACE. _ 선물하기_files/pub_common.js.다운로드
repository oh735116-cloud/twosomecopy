// 기간 설정 라디오
function getToday(){
    var now = new Date();
    var year = now.getFullYear();
    var month = now.getMonth() + 1;    //1월이 0으로 되기때문에 +1을 함.
    var date = now.getDate();

    month = month >=10 ? month : "0" + month;
    date  = date  >= 10 ? date : "0" + date;
	return today = year + "-" + month + "-" + date
}
// 1,3,6,12개월 전 날짜 반환
// 20210326 수정 : 1주일, 2주, 3주 추가
function setLastMonth(dt, mm) {
	var d = new Date(dt); 
	var lastDayofLastMonth = ( new Date( d.getYear(), d.getMonth(), 0) ).getDate(); 
	if(d.getDate() > lastDayofLastMonth) {
		d.setDate(lastDayofLastMonth); 
	} 
	// 개월 mm : 1, 3, 6, 12
	// 주일 mm : 0.1, 0.2, 0.3
	var dayOfMonth = d.getDate();
	if (mm == '0.1') {
		d.setDate(dayOfMonth - 6);
	} else if (mm == '0.2') {
		d.setDate(dayOfMonth - 13);
	} else if (mm == '0.3') {
		d.setDate(dayOfMonth - 20);
	} else {
		var month = d.getMonth() - mm;
		d.setMonth(month);
	}
	$('.datepicker-from').datepicker('setDate', d );
}
$(document).on('click', '.datepicker-radio-wrap input[type=radio]', function() {
	$('.datepicker-to').datepicker('setDate', getToday() );
	if ($(this).val() === 0) {
		$('.datepicker-from').datepicker('setDate', getToday() );
	} else {
		setLastMonth(getToday(), $(this).val());
	}
});

