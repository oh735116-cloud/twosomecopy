/*****************************************************************************
특정문자의 공백전환(예: 2020/11/24  - 20201124)
sStr : string 값
sSrc : 공백으로 전환되는 값
*****************************************************************************/
function trimNum(sStr) {
   var sNum    	=	"0123456789";
   var sResult 	= 	"";

   for (var i = 0; i < sStr.length; i++ ) {

       if( -1 != sNum.indexOf(sStr.charAt(i)) ) {
           sResult = sResult + sStr.charAt(i);
       }
   }
   return sResult;
}


