/*****************************************************************************
날짜 한글명 요일 가져오기 - param형태 (ex) 2024.05.15, 2024-05-15)
*****************************************************************************/
function getDayOfWeekKor(yyyyMMdd){	
	const week = ['일', '월', '화', '수', '목', '금', '토'];
	const dayOfWeek = week[new Date(yyyyMMdd).getDay()];
    //0:일, 1:월, 2:화, 3:수, 4:목, 5:금, 6:토
    return dayOfWeek;
}

/*****************************************************************************
현재 일시 기준 날짜 포멧 (날짜:yyyy-mm-dd(요일) hh:mm:ss) - 홀케이크 상세 에서 사용됨
*****************************************************************************/
function getCurDateYMDHMS(){
	
	var datetime = new Date();

    var year = datetime.getFullYear();              //yyyy
    var month = (1 + datetime.getMonth());          //M
    month = month >= 10 ? month : '0' + month;  //month 두자리로 저장
    var day = datetime.getDate();                   //d
    day = day >= 10 ? day : '0' + day;          //day 두자리로 저장
    
	var hour = datetime.getHours();
	var mm   = datetime.getMinutes();
	mm = mm >= 10 ? mm : '0' + mm;
	var ss   = datetime.getSeconds();
	ss = ss >= 10 ? ss : '0' + ss;
	
    return year + '-' + month + '-' + day +'(' + getDayOfWeekKor(year + '-' + month + '-' + day) + ') ' + hour + ':' + mm + ':' + ss ;
}
/*****************************************************************************
현재 일시 기준 날짜 포멧 (날짜:mm/dd(요일)) - 매장리스트에서 사용됨
