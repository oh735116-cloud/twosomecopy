(공통) Cookie값 Setting하기
 @ params  name   : 쿠키명
           value  : 쿠키값
           expire : 기간 
*****************************************************************************/
function setCookie(name, value, expire) {
	var expire_date = new Date(expire);
	document.cookie = name + "=" + escape(value) + "; path=/; expires=" + expire_date.toGMTString();
}

