/*****************************************************************************
날짜 포멧 (날짜:yyyy-mm-dd)
ex) 20210308 -> 2021-03-08
*****************************************************************************/
function getFormatDate(strDate){
	
	var strDate = new Date(strDate.substring(0,4), strDate.substring(4,6)-1, strDate.substring(6,8));
	
    var year = strDate.getFullYear();              //yyyy
    var month = (1 + strDate.getMonth());          //M
    month = month >= 10 ? month : '0' + month;  //month 두자리로 저장
    var day = strDate.getDate();                   //d
    day = day >= 10 ? day : '0' + day;          //day 두자리로 저장
    return  year + '-' + month + '-' + day;       //yyyy-mm-dd
}

/*****************************************************************************
날짜 포멧 (날짜:yyyy-mm-dd hh:mm)
*****************************************************************************/
function getFormatDateTime(strDate){
	
	if( strDate == null || strDate == ""){
		return "";
	}else{
	
		var datetime = new Date(strDate.substring(0,4), strDate.substring(4,6)-1, strDate.substring(6,8), strDate.substring(8,10),strDate.substring(10,12));
		
		var hour = datetime.getHours();
		var mm   = datetime.getMinutes();
		mm = mm >= 10 ? mm : '0' + mm;
		var ss   = datetime.getSeconds();
		ss = ss >= 10 ? ss : '0' + ss;
	
    return getFormatDate(strDate) +' ' + hour + ':' + mm ;       //yyyy-mm-dd
	}
}

/*****************************************************************************
날짜 유효성 체크 (날짜:yyyy-mm-dd hh:mm)
 from ~ to  개월 수 이상일 경우  false 
*****************************************************************************/
function chkFromToData(stDate, edDate, chkMonth) {
	stDate = stDate.replaceAll("-", "");
	edDate = edDate.replaceAll("-", "");
	
	var startDate = new Date(stDate.substring(0,4), stDate.substring(4,6)-1, stDate.substring(6,8));
	var endDate   = new Date(edDate.substring(0,4), edDate.substring(4,6)-1, edDate.substring(6,8));
	
	var tmpMonth =  startDate;
	
	tmpMonth.setMonth( startDate.getMonth() + chkMonth);
	
	if(tmpMonth < endDate) {
		return false;
	}else {
		return true;
	}
}

/*****************************************************************************
date 날짜 포맷 변경 yyyymmdd
 - 파라미터 - date : new Date() 날짜
*****************************************************************************/
function getDateToStr(date) {
	var year   = date.getFullYear(); // 연도
	var month  = date.getMonth() + 1;// 월    
	var day    = date.getDate();     // 일
	
	month = (month < 10) ? "0" + month : month;
	day = (day < 10) ? "0" + day : day;
	return year +""+ month +""+ day;
}

/*****************************************************************************
yyyymmdd 날짜 스트링을 Date형으로 반환
*****************************************************************************/
function getStrToDate(dateStr) {
	var yyyyMMdd = String(dateStr);
	var sYear  = yyyyMMdd.substring(0,4);
	var sMonth = yyyyMMdd.substring(4,6);
	var sDate  = yyyyMMdd.substring(6,8);
	
	return new Date(Number(sYear), Number(sMonth)-1, Number(sDate));
}

