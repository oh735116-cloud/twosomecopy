/**
 * WEB-APP간 인터페이스
 * @param funcName		호출할 함수명
 * @param paramObj		전달할 파라미터
 * @param callbackFunc	콜백받을 함수명
 */
var interfaceAppData = function(funcName, paramObj, callbackFunc) {

	//APP에 전달할 object 설절
	var obj = {
		        name     : funcName,
		        param    : paramObj,
		        callback : callbackFunc
        	   };
    //IOS인 경우 처리
    if (_isAppIOS) {
        if(typeof webkit !== "undefined") {

        	webkit.messageHandlers.callNative.postMessage(obj);
        }
    //ANDROID인 경우    
    } else if (_isAppAndroid) {
    	if( window.TsJSInterface != undefined) {
            window.TsJSInterface.callNative(JSON.stringify(obj));
        }
    } else {
    	toastAlert("정확한 앱정보가 없습니다.");
    }
}

/**
 * WEB-APP간 인터페이스(애드브릭스용도=TAGGING)
 * @param funcName		호출할 함수명
 * @param paramObj		전달할 파라미터
 */
var interfaceAdBrixData = function(funcName, paramObj) {
    var strParam = '';
    if(paramObj != undefined && paramObj != null && paramObj != '') {
        strParam = JSON.stringify(paramObj);
    }
    
    try {
        //IOS인 경우 처리
        if (_isAppIOS) {
            if(_isAdBrixIOS == false || typeof webkit == 'undefined') {
                return;
            }
            var requestParam = {
                    name : funcName
                  , param: paramObj || {}
            };
            webkit.messageHandlers.adbrix.postMessage(requestParam);
            /*
            var url = 'adbrix://' + funcName + '?' + encodeURIComponent(strParam);
            if($('body').length > 0 && $('#adBrixIframe').length == 0) {
                // IFRAME이 없는 경우 IFRAME 생성후 전송
                $('body').append('<iframe id="adBrixIframe" src="' + url + '" style="display: none;" />');
            } else {
                $('#adBrixIframe').attr('src', url);
            }
            */
        //ANDROID인 경우
        } else if (_isAppAndroid) {
            if(_isAdBrixAndroid == false) {
                return;
            }
            if(window.adbrix != undefined) {
                if(strParam == '') {
                    window.adbrix[funcName]();
                } else {
                    window.adbrix[funcName](strParam);
                }
            }
        } else {
            if(_isAdBrixAndroid == false) {
                return;
            }
            console.log('[ADBRIX] %s : %o\n%s', funcName, paramObj, strParam);
            toastAlert('정확한 앱정보가 없습니다.');
        }
    } catch(e) {
        console.log('ADBRIX ERROR');
    }
}


