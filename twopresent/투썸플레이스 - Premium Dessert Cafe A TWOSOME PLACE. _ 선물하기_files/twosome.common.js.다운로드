                document.cookie = "survUrl=" + data.survUrl + "; max-age=" + (5*60) + "; path=/"; // survUrl쿠키 유지시간 셋팅(초단위)
                document.cookie = "survNo=" + data.survNo + "; max-age=" + (5*60) + "; path=/"; // survNo쿠키 유지시간 셋팅(초단위)
                $("#divMainStripBanner").hide();
            } else{
                $("#surveyUrlInfo").val(""); // 설문URL
                $("#survNo").val(""); // 설문URL
            	$(".survey_box").hide();
//            	document.cookie = 'surveyYn=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';// surveyYn쿠키 제거
//            	document.cookie = 'survUrl=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';// survUrl쿠키 제거

                document.cookie = "surveyYn=Y; max-age=" + (5*60) + "; path=/"; // surveyYn쿠키 유지시간 셋팅(초단위)
                document.cookie = "survUrl=; max-age=" + (5*60) + "; path=/"; // survUrl쿠키 유지시간 셋팅(초단위)
                document.cookie = "survNo=; max-age=" + (5*60) + "; path=/"; // survNo쿠키 유지시간 셋팅(초단위)
                $("#divMainStripBanner").show();
            }
